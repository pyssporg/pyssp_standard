<ns0:SystemStructureDescription xmlns:ns0="http://ssp-standard.org/SSP1/SystemStructureDescription" name="MixedSSD" version="1.0" xmlns:ssd="http://ssp-standard.org/SSP1/SystemStructureDescription"><ns0:System name="system"><ns0:Elements><ns0:Component name="Plant" source="resources/plant.fmu" /><ns0:Component name="Controller" source="resources/controller.fmu" /></ns0:Elements><ns0:ParameterBindings><ns0:ParameterBinding target="Plant"><ns0:ParameterSet version="2.0" name="PlantInline">
  <ns0:Parameters>
    <ns0:Parameter name="gain">
      <ns0:Real value="1.5" />
    </ns0:Parameter>
    <ns0:Parameter name="offset">
      <ns0:Real value="2.0" />
    </ns0:Parameter>
  </ns0:Parameters>
</ns0:ParameterSet></ns0:ParameterBinding><ns0:ParameterBinding target="Controller" source="external_values.ssv" /></ns0:ParameterBindings></ns0:System></ns0:SystemStructureDescription>